# Local environment config for arm-vm scripts (ssh/*.sh, oci-infra/*.sh).
# Copy this to .env and fill in real values — .env is gitignored, this
# example file is the only one committed.
#
# Nothing in here is a secret (those live in Bitwarden — see lib/bw.sh and
# oci-infra/README.md). This is just resource identifiers/config that were
# previously hardcoded across scripts.

# VM connection
VM_USER=ubuntu
# The VM's public IP. oci-infra scripts discover this fresh via the OCI API
# on every run and ignore this value unless you export VM_IP yourself
# beforehand; ssh/connect.sh and ssh/load-gen.sh have no OCI API call, so
# they use this directly.
VM_IP=80.225.254.55

# OCI resource identifiers (arm-vm instance)
INSTANCE_ID=ocid1.instance.oc1.ap-mumbai-1.REPLACE_ME
AVAILABILITY_DOMAIN=REPLACE_ME:AP-MUMBAI-1-AD-1

# Block storage (oci-infra/setup.sh)
DATA_VOLUME_NAME=arm-vm-data
DATA_VOLUME_SIZE_GB=150
DATA_MOUNT_POINT=/mnt/data

# Application databases (oci-infra/setup-postgres.sh). Each is created owned by
# the unprivileged app role (the arm-vm-postgres vault item's `app_user`, which
# should be `foyeriq`) and locked so only that role can connect. Non-secret.
APP_DB_MARKETING=foyeriq_marketing
APP_DB_APP=foyeriq_app

# Bitwarden vault item names (lib/bw.sh consumers) — change these if you
# rename the items in your vault.
BW_ITEM_SSH_KEY=arm-vm-ssh-key
BW_ITEM_OCI_KEY=arm-vm-oci-api-key
BW_ITEM_POSTGRES=arm-vm-postgres
BW_ITEM_REDIS=arm-vm-redis
